#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODEL="${CODEX_BUILD_MODEL:-gpt-5.3-codex}"
EFFORT="${CODEX_BUILD_REASONING_EFFORT:-medium}"

PROMPT="Use the repository skill at .agents/skills/build/SKILL.md. Read it first and execute the build phase for the current repository state."

if (($# > 0)); then
  PROMPT="${PROMPT}

Additional operator instructions:
$*"
fi

exec codex exec \
  -C "$ROOT_DIR" \
  -m "$MODEL" \
  -c "reasoning_effort=\"$EFFORT\"" \
  "$PROMPT"
